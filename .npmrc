# Cross-platform install — fetch native binaries for both Windows and Linux so
# the same node_modules can be shared between a Windows host (PowerShell/cmd)
# and WSL/Ubuntu simultaneously without re-running `pnpm install` after each
# OS switch. Applies to esbuild, rollup, tsx, vitest, oxlint, etc.
#
# Docs: https://pnpm.io/settings#supportedarchitectures
#
# Trade-off: node_modules is larger by ~50-100 MB because each native
# addon ships per platform. Drop the unused OS here to halve the footprint
# on single-platform machines.
supported-architectures[os][]=win32
supported-architectures[os][]=linux
supported-architectures[cpu][]=x64
supported-architectures[cpu][]=arm64
