# API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://custom.openai-compat.example/v1

# Agent model (optional; defaults: gpt-4o-mini for openai, claude-sonnet-4-20250514 for anthropic)
# Prefix "claude-..." auto-selects the Anthropic adapter; anything else → OpenAI.
# AGENT_MODEL=gpt-4o-mini
# AGENT_PROVIDER=openai        # optional override: 'openai' | 'anthropic'

# Gateway daemon (agent gateway start / tui)
# AGENT_GATEWAY_PORT=18790
# AGENT_GATEWAY_HOST=127.0.0.1
# AGENT_GATEWAY_TOKEN=dev-token
# AGENT_STATE_DIR=~/.agent     # logs, pidfile, sessions.db, memory, ego state
